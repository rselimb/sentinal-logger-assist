# Sentinel-V Environment Configuration
# Copy this to .env and update with your actual values

# Database
SENTINEL_DB_PATH=./data/sentinel.db

# Dashboard Settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000

# Log Paths
SSH_LOG_PATH=/var/log/auth.log
WEB_LOG_PATH=/var/log/nginx/access.log

# Discord Notifications
# Get your webhook URL from Discord Server Settings > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANNEL_ID/WEBHOOK_TOKEN

# Additional Configuration
# SSH brute-force threshold
SSH_FAILED_THRESHOLD=5

# GeoIP API
# Using free ip-api.com by default (no key required)
GEOIP_API_URL=http://ip-api.com/json/
